# Database
DATABASE_URL=sqlite:///./data/35gateway.sqlite3

# Billing
POWER_RATE_CNY=1000
CREEM_ENABLED=false
CREEM_ENV=test
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_BASE_URL=
CREEM_SUCCESS_URL=
