# 35gateway console backend environment

# App
APP_ENV=dev
API_PREFIX=
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5185,http://127.0.0.1:5186,http://127.0.0.1:5187
ADMIN_API_KEY=

# URLs
SITE_URL=http://127.0.0.1:8025
SITE_CONSOLE_URL=/console
SITE_BIZ_QR_URL=
SITE_BIZ_CONTACT_LABEL=
SITE_BIZ_CONTACT_VALUE=
